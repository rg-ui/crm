# Supabase — get these from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct PostgreSQL connection (for /api/init schema setup)
# Get from: Supabase Dashboard > Settings > Database > Connection string (Transaction mode)
DATABASE_URL=postgresql://postgres.your-project:[YOUR-DB-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Google OAuth 2.0 — get these from Google Cloud Console > APIs & Services > Credentials
# Create an OAuth 2.0 Client ID for Web application, add redirect URI:
#   http://localhost:3000/api/integrations/google/callback (dev)
#   https://yourdomain.com/api/integrations/google/callback (prod)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Public app URL (for OAuth redirect construction)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Cloud project number (from Google Cloud Console > IAM & Admin > Settings)
GOOGLE_PROJECT_NUMBER=your-project-number
